append variables
  -
    var invest= [
      {
        image:'short-terms.png',
        title  :'CLOUD SOLUTIONS',
        subTitle  :'Scalable Infrastructure',
        text: 'Migrate to the cloud with confidence. We design and manage secure, scalable cloud architectures tailored to your needs.',
        bg: 'bg-dark-gradient',
        btnText:'Learn More',
      },
      {
        image:'fully-funded.png',
        title  :'AI & DATA ANALYTICS',
        subTitle  :'Data-Driven Insights',
        text: 'Harness the power of AI and big data to uncover actionable insights that drive smarter business decisions.',
        bg: 'bg-light-gradient',
        btnText:'Explore',
      },

    ];


mixin InvestCard(config)
  .col-md-6.mb-5
    .card.text-white
      img.card-img(src=`${CWD}assets/img/gallery/${config.image}` alt='...')
      .card-img-overlay.d-flex.flex-column.justify-content-center.px-5.px-md-3.px-lg-5(class=`${config.bg}`)
        h6.text-success.pt-2=config.title
        hr.text-white(style='height:0.12rem;width:2.813rem')
        .pt-lg-3
          h6.fw-bold.text-white.fs-1.fs-md-2.fs-lg-3.w-xxl-50=config.subTitle
          p.w-xxl-75=config.text
          button.btn.btn-lg.btn-light.text-success(type='button')=config.btnText

mixin Invest
  +Section.py-5#solutions
    .row.justify-content-center
      .col-xl-9.mb-3
        .row
          .col-lg-9.mb-3
            h5.fw-bold.fs-3.fs-lg-5.lh-sm.mb-3 Solutions for Every Challenge
            p.mb-5 We deliver end-to-end technology solutions that empower businesses to innovate, scale, and stay ahead of the competition in today's digital landscape.
          each item in invest
            +InvestCard(item)
