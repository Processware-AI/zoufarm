append variables
  -
    var opportunities= [
      {
        image:'farmer.svg',
        title  :'Process Automation',
        text: 'Eliminate repetitive tasks and manual workflows with intelligent automation. Our RPA and AI-powered tools accelerate operations and reduce human error.',
      },
      {
        image:'growth.svg',
        title  :'System Integration',
        text: 'Seamlessly connect your existing enterprise systems, databases, and cloud services into a unified platform that enables real-time data flow and collaboration.',
      },
      {
        image:'planting.svg',
        title  :'Custom Development',
        text: 'From web applications to enterprise solutions, our expert team builds tailored software that perfectly fits your unique business requirements and goals.',
      },

    ];

mixin Opportunity(config)
  .col-md-4.mb-5
    .card.h-100.shadow.px-4.px-md-2.px-lg-3.card-span.pt-6
      .text-center.text-md-start.card-hover
        img(src=`${CWD}assets/img/icons/${config.image}` height="60" alt='').ps-3.icons
        .card-body
          h6.fw-bold.fs-1.heading-color=config.title
          p.mt-3.mb-md-0.mb-lg-2=config.text

mixin Opportunities
  section.py-5#services
    +Background({ image: `${CWD}assets/img/illustrations/bg.png`, attrs: { style: { 'background-position': 'top left', 'background-size': '225px 755px','margin-top': '-17.5rem'} }, className: 'd-none d-sm-block' })
    .container
      .row
        .col-lg-9.mx-auto.text-center.mb-3
          h5.fw-bold.fs-3.fs-lg-5.lh-sm.mb-3 Our Services
          p.mb-5 We provide comprehensive IT solutions designed to transform your business operations and accelerate growth.
      .row.flex-center.h-100
        .col-xl-9
          .row
            each Opportunity in opportunities
              +Opportunity(Opportunity)
