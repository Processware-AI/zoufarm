mixin HeroHeader
  section.py-0#header
    +Background({ image: `${CWD}assets/img/illustrations/hero-header.png`, attrs: { style: { 'background-position': 'right top', 'background-size': 'contain'} }, className: 'd-none d-md-block' })
    +Background({image: `${CWD}assets/img/illustrations/hero-bg.png`, attrs: { style: { 'background-position': 'right top', 'background-size': 'contain'} }, className: 'd-md-none' })
    .container
      .row.align-items-center.min-vh-75.min-vh-lg-100
        .col-md-7.col-lg-6.col-xxl-5.py-6.text-sm-start.text-center
          h1.mt-6.mb-sm-4.fw-semi-bold.lh-sm.fs-4.fs-lg-5.fs-xl-6 Intelligent Process
            br.d-block.d-lg-block
            |Automation Solutions
          p.mb-4.fs-1 Processware delivers cutting-edge software solutions that streamline your business processes, boost productivity, and drive digital transformation for enterprises of all sizes.
          a.btn.btn-lg.btn-success(href='#contact' role='button') Get Started
