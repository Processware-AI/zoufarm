
mixin TabContent(config)
  .row.align-items-center.my-6.mx-auto
    .col-md-6.col-lg-5.offset-md-1
      h3.fw-bold.lh-base.text-white=config.title
    .col-md-5.text-white.offset-lg-1
      p.mb-0=config.text

mixin HowItWorksTab
  ul.nav.justify-content-between
    li.nav-item(role='presentation')
      a(href='#bootstrap-tab1' data-bs-toggle='tab' data-bs-target='#tab1'  ).nav-link.active.fw-semi-bold#tab-1
        span.nav-item-circle-parent
          span.nav-item-circle
            | 01

    li.nav-item(role='presentation')
      a(href='#bootstrap-tab2' data-bs-toggle='tab' data-bs-target='#tab2').nav-link.fw-semi-bold#tab-2
        span.nav-item-circle-parent
          span.nav-item-circle
            | 02

    li.nav-item(role='presentation')
      a(href='#bootstrap-tab3' data-bs-toggle='tab'  data-bs-target='#tab3').nav-link.fw-semi-bold#tab-3
        span.nav-item-circle-parent
          span.nav-item-circle
            | 03

    li.nav-item(role='presentation')
      a(href='#bootstrap-tab4' data-bs-toggle='tab' data-bs-target='#tab4').nav-link.fw-semi-bold#tab-4
        span.nav-item-circle-parent
          span.nav-item-circle
            | 04

  .tab-content#myTabContent
    .tab-pane.fade.show.active#tab1(role='tabpanel' aria-labelledby='tab-1')
      +TabContent({title: 'Discovery & Analysis: We listen to understand your business challenges.', text: 'Our consultants work closely with your team to analyze existing workflows, identify pain points, and define clear objectives for digital transformation.'})
    .tab-pane.fade#tab2(role='tabpanel' aria-labelledby='tab-2')
      +TabContent({title: 'Strategy & Design: We architect the perfect solution for your needs.', text: 'Based on our analysis, we design a comprehensive solution blueprint including technology stack, integration points, and implementation roadmap with clear milestones.'})
    .tab-pane.fade#tab3(role='tabpanel' aria-labelledby='tab-3')
      +TabContent({title: 'Development & Integration: We build and connect with precision.', text: 'Our agile development team brings the solution to life, integrating seamlessly with your existing systems while maintaining rigorous quality assurance at every step.'})
    .tab-pane.fade#tab4(role='tabpanel' aria-labelledby='tab-4')
      +TabContent({title: 'Deployment & Support: We ensure long-term success and growth.', text: 'After thorough testing, we deploy your solution and provide ongoing maintenance, monitoring, and optimization to ensure peak performance and continuous improvement.'})


mixin HowItWorks
  section.py-0
    +Background({ image: `${CWD}assets/img/illustrations/how-it-works.png`, attrs: { style: { 'background-position': 'center bottom', 'background-size': 'cover'} }, className: '' })
    .container-lg
      .row.justify-content-center
        .col-sm-8.col-md-9.col-xl-5.text-center.pt-8
          h5.fw-bold.fs-3.fs-xxl-5.lh-sm.mb-3.text-white How We Work
          p.mb-5.text-white Our proven four-step methodology ensures every project is delivered on time, within budget, and exceeds expectations. From initial consultation to ongoing support, we are your trusted technology partner.
        .col-sm-9.col-md-12.col-xxl-9
          .theme-tab
            +HowItWorksTab
